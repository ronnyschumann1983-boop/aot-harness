{
  "name": "n8n-nodes-aot-harness",
  "version": "0.4.6",
  "description": "CHIP + Atom of Thoughts (AoT) Agent Harness — multi-provider n8n community node (Anthropic, OpenAI, Google, Mistral, OpenRouter) with pluggable vaults (Obsidian, Supabase) and Human-in-the-Loop gate",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "aot",
    "atom-of-thoughts",
    "chip",
    "ai-agent",
    "agent",
    "llm",
    "reasoning",
    "rag",
    "vault",
    "obsidian",
    "supabase",
    "hitl",
    "human-in-the-loop",
    "anthropic",
    "claude",
    "openai",
    "google",
    "gemini",
    "mistral",
    "openrouter",
    "multi-provider",
    "cost-optimization",
    "gdpr",
    "harness"
  ],
  "license": "MIT",
  "author": {
    "name": "Ronny Schumann"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/AnthropicAotApi.credentials.js",
      "dist/credentials/OpenAiAotApi.credentials.js",
      "dist/credentials/GoogleGeminiAotApi.credentials.js",
      "dist/credentials/MistralAotApi.credentials.js",
      "dist/credentials/OpenRouterAotApi.credentials.js",
      "dist/credentials/AotHarnessApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/AotHarness/AotHarness.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "n8n-workflow": "*",
    "typescript": "^5.0.0"
  }
}
